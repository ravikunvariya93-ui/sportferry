# Environment variables configuration guide
# Copy this file to .env.local and fill in the specifics.

# MongoDB Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/sportferry?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/sportferry

# NextAuth configuration
# Generate a secret via: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# Usually the canonical URL of your site. Needed for some providers and Auth.js.
NEXTAUTH_URL=http://localhost:3000
