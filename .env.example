# ──────────────────────────────────────────
# Sportferry — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env.local and fill in values.

# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGODB_URI=

# NextAuth secret — must be a random string of at least 32 characters in production
# Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of your app (required in production)
# Examples:
#   http://localhost:3000          (local dev)
#   http://175.29.21.9:8888        (your own server)
#   https://sportferry.vercel.app  (Vercel)
NEXTAUTH_URL=
